{
  "name": "galactic-spacefarer-ui",
  "version": "0.0.1",
  "description": "An SAP Fiori application.",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "devDependencies": {
    "@sap-ux/eslint-plugin-fiori-tools": "^10.0.0",
    "@sap/ux-ui5-tooling": "1",
    "@sapui5/types": "~1.148.0",
    "@ui5/cli": "^4.0.53",
    "eslint": "^10",
    "typescript": "^5.9.3",
    "ui5-middleware-livereload": "^3.3.0",
    "ui5-middleware-simpleproxy": "^3.7.0",
    "ui5-tooling-transpile": "^3.11.0"
  },
  "scripts": {
    "start": "ui5 serve --open index.html",
    "build": "ui5 build --clean-dest",
    "deploy-config": "npx -p @sap/ux-ui5-tooling fiori add deploy-config cf"
  }
