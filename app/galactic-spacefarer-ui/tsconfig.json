{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "./webapp",
    "outDir": "./dist",
    "paths": {
      "galactic/spacefarer/galacticspacefarerui/*": [
        "./webapp/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules/@sapui5/types",
      "../../node_modules/@types",
      "../../node_modules/@sapui5/types"
    ]
  },
  "include": [
    "./webapp/**/*.ts",
    "./webapp/**/*.d.ts"
  ],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.js"
  ]
}