{
  "name": "galactic-spacefarer-adventure",
  "version": "1.0.0",
  "dependencies": {
    "@sap/cds": "^9.9.1"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.39.1",
    "@cap-js/cds-types": "^0.17.0",
    "@cap-js/sqlite": "^2.4",
    "cds-plugin-ui5": "^0.13.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-galactic-spacefarer-ui": "cds watch --open galactic.spacefarer.galacticspacefarerui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/galactic-spacefarer-ui"
  ],
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "alice": {
            "password": "alice",
            "roles": [
              "SpacefarerViewer",
              "SpacefarerEditor"
            ],
            "attr": {
              "planetId": "1"
            }
          },
          "bob": {
            "password": "bob",
            "roles": [
              "SpacefarerViewer",
              "SpacefarerEditor"
            ],
            "attr": {
              "planetId": "2"
            }
          },
          "admin": {
            "password": "admin",
            "roles": [
              "SpacefarerAdmin"
            ],
            "attr": {
              "planetId": "*"
            }
          }
        }
      }
    }
  }
}
